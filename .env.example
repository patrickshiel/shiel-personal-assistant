# Identity: personal (patrick@shiel.io) and work (patrick@xwave.ie)
PERSONAL_EMAIL=patrick@shiel.io
WORK_EMAIL=patrick@xwave.ie

# LLM (use one or more; set the one you use in code)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# LangSmith (optional) — set LANGCHAIN_API_KEY to see traces in LangSmith Studio
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=shiel-personal-assistant
# If your key is org-scoped, set workspace (LangSmith → Settings → Workspace ID):
# LANGSMITH_WORKSPACE_ID=

# Google Calendar — OAuth per account. See docs/SETUP.md.
# Personal (and default): one OAuth client + refresh token
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback
# Run: npm run auth-google -- --personal   then  npm run auth-google -- --work
GOOGLE_REFRESH_TOKEN_PERSONAL=
GOOGLE_REFRESH_TOKEN_WORK=
# If work is in a different Google org: create a second OAuth client in that org's GCP project, then set:
# GOOGLE_CLIENT_ID_WORK=
# GOOGLE_CLIENT_SECRET_WORK=
# Legacy single account:
# GOOGLE_REFRESH_TOKEN=

# Todoist — one token per account (personal vs work)
TODOIST_API_TOKEN_PERSONAL=
TODOIST_API_TOKEN_WORK=
# Legacy single account:
# TODOIST_API_TOKEN=
# Optional: if you get 410 or other API errors, try: TODOIST_API_BASE=https://api.todoist.com/rest/v2
# TODOIST_API_BASE=

# Obsidian — personal vault; optional separate work vault
OBSIDIAN_VAULT_PATH=/Users/you/Documents/ObsidianPersonal
OBSIDIAN_VAULT_PATH_WORK=

# Optional: require approval before send/delete (true/false)
REQUIRE_APPROVAL_FOR_WRITES=true
