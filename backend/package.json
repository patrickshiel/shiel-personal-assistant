{
  "name": "shiel-personal-assistant",
  "version": "0.1.0",
  "description": "Local personal assistant agent: calendar, Todoist, email, Obsidian (LangGraph + Node)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:server": "node dist/server.js",
    "dev": "tsx src/index.ts",
    "agent": "tsx src/index.ts",
    "dev:server": "tsx src/server.ts",
    "orchestrate": "tsx src/orchestrate.ts",
    "debrief": "tsx src/run-debrief.ts",
    "weekly-prep": "tsx src/run-weekly-prep.ts",
    "carve-time": "tsx src/orchestrate.ts -- --once carve_priority_time",
    "resync-day": "tsx src/run-resync-day.ts",
    "auth-google": "tsx src/scripts/auth-google.ts",
    "todoist-test": "tsx src/scripts/todoist-test.ts",
    "smoke:approval-flow": "tsx src/scripts/smoke-test-approval-flow.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "langgraph",
    "agent",
    "calendar",
    "todoist",
    "obsidian",
    "personal-assistant"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph": "^0.2.0",
    "@langchain/openai": "^0.3.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.0",
    "express": "^5.2.1",
    "googleapis": "^144.0.0",
    "gray-matter": "^4.0.3",
    "langchain": "^0.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
