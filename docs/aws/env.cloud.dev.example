# Backend runtime env (ECS task definition)
NODE_ENV=production
PORT=3001
AUTH_REQUIRED=true
CORS_ALLOWED_ORIGINS=https://<your-amplify-domain>

STATE_STORE_BACKEND=dynamodb
JOBS_TABLE_NAME=shiel-assistant-dev-assistant-jobs
ORCHESTRATOR_TABLE_NAME=shiel-assistant-dev-orchestrator-state
MEMORY_TABLE_NAME=shiel-assistant-dev-memory-entries
USER_PARTITION_KEY=default

COGNITO_REGION=eu-west-1
COGNITO_USER_POOL_ID=eu-west-1_xxxxxxxxx
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Put sensitive values in Secrets Manager and inject via ECS `secrets`.
OPENAI_API_KEY=<secret>
ANTHROPIC_API_KEY=<secret>
GOOGLE_CLIENT_SECRET=<secret>
GOOGLE_REFRESH_TOKEN_PERSONAL=<secret>
GOOGLE_REFRESH_TOKEN_WORK=<secret>
TODOIST_API_TOKEN_PERSONAL=<secret>
TODOIST_API_TOKEN_WORK=<secret>

# Frontend runtime env (Amplify)
NEXT_PUBLIC_BACKEND_URL=https://<backend-alb-domain>
NEXT_PUBLIC_AUTH_ENABLED=true
NEXT_PUBLIC_COGNITO_DOMAIN=<domain-prefix>.auth.eu-west-1.amazoncognito.com
NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_COGNITO_REDIRECT_URI=https://<your-amplify-domain>
NEXT_PUBLIC_COGNITO_LOGOUT_URI=https://<your-amplify-domain>
NEXT_PUBLIC_COGNITO_SCOPE=openid email profile
